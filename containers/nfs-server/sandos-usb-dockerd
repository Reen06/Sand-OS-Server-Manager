#!/bin/bash
# Root helper: start/stop a SECOND dockerd instance rooted on an assigned USB
# drive, so an app's IMAGE can live on that drive instead of the node's own
# disk. Docker can't split one daemon's image storage per-image across mount
# points — a second daemon with its own --data-root is the actual mechanism,
# not a workaround. Installed at /usr/local/bin/sandos-usb-dockerd, allowed
# via sudoers for the SM user (same narrow-scope pattern as sandos-usb-bind).
#
#   sandos-usb-dockerd start <uuid> <mountpoint>
#   sandos-usb-dockerd stop  <uuid>
#
# `start` writes /run/sandos-usb-docker-<uuid>.env (consumed by the templated
# unit below) and enables+starts sandos-usb-dockerd@<uuid>.service. `stop`
# disables+stops it. The drive's OWN data (<mountpoint>/SandOS/app-hosting/)
# is never touched by stop — only the running daemon process goes away.
#
# Everything SandOS puts on a drive lives under ONE visible top-level
# "SandOS/" folder (+ the small pre-existing .sandos-storage.md marker at the
# drive root) — personal files elsewhere on the drive are never touched.
set -euo pipefail

UUID_RE='^[a-zA-Z0-9-]+$'

_write_readme() {
  local root="$1/SandOS"
  mkdir -p "$root"
  cat > "$root/README.md" <<'EOF'
# SandOS — please don't edit these folders by hand

This drive is registered with a Sand-OS Server Manager. Everything it needs
lives inside THIS "SandOS" folder — your own files elsewhere on the drive
are never touched or moved.

- `app-hosting/docker-data/` and `app-hosting/containerd-root/` — a second
  Docker daemon + its own separate containerd, private image storage (so
  an app's image can live on this drive instead of the server's own disk).
  Opaque internal format — editing or deleting anything in here can
  corrupt every app whose image lives on this drive.
- `app-hosting/apps/<app-id>/appdef.json` — a small, portable description
  of one app (name, icon, how to launch it), so plugging this drive into
  a DIFFERENT Server Manager lets it offer to import that app. Safe to
  read, not meant to be hand-edited.
- `data-mounts/<app-id>/<user>/<mount-name>/` — one app's actual saved
  data (settings, files) when you've chosen to store it here instead of
  on the server's own disk.

All of this is managed through the Sand-OS dashboard (Fleet page, and each
app's gear menu → Storage/Image location) — you shouldn't need to touch
any of it by hand. Deleting a folder here permanently removes that
data/image.
EOF
}

case "${1:-}" in
  start)
    uuid="${2:-}"; mountpoint="${3:-}"
    NAS="${NAS_ROOT:-/home/control/sandos-nas}"
    [[ "$uuid" =~ $UUID_RE ]] || { echo "bad uuid" >&2; exit 2; }
    # A drive also assigned to NAS sharing is bind-mounted at TWO paths for the
    # same underlying storage — lsblk (and thus usb_storage.mountpoint_for())
    # may report either one. Accept both the raw udisksctl mount and the NAS
    # graft targets (matching sandos-usb-bind's own dst patterns) since they're
    # the identical bytes either way.
    [[ "$mountpoint" == /media/* || "$mountpoint" == /run/media/* \
       || "$mountpoint" == "$NAS"/users/*/USB-* || "$mountpoint" == "$NAS"/shared/media/USB-* ]] \
        || { echo "bad mountpoint" >&2; exit 2; }
    [[ "$mountpoint" == *..* ]] && { echo "bad path" >&2; exit 2; }
    mountpoint -q "$mountpoint" || { echo "not a mountpoint" >&2; exit 2; }
    mkdir -p "$mountpoint/SandOS/app-hosting/docker-data"
    mkdir -p "$mountpoint/SandOS/app-hosting/containerd-root"
    _write_readme "$mountpoint"
    printf 'SANDOS_USB_MOUNTPOINT=%s\n' "$mountpoint" > "/run/sandos-usb-docker-${uuid}.env"
    # containerd first — dockerd's --containerd flag only ever CONNECTS to an
    # already-running containerd, it never spawns one itself. Without this
    # separate instance dockerd silently falls back to the HOST's own
    # containerd, and an image "moved" to USB never actually leaves local
    # disk (hit live). `Requires=`/`After=` on the dockerd unit itself also
    # pulls this in automatically, but starting it explicitly here first
    # keeps the ordering obvious and lets `enable` cover both units.
    systemctl enable --now "sandos-usb-containerd@${uuid}.service"
    systemctl enable --now "sandos-usb-dockerd@${uuid}.service"
    ;;
  stop)
    uuid="${2:-}"
    [[ "$uuid" =~ $UUID_RE ]] || { echo "bad uuid" >&2; exit 2; }
    systemctl disable --now "sandos-usb-dockerd@${uuid}.service" 2>/dev/null || true
    systemctl disable --now "sandos-usb-containerd@${uuid}.service" 2>/dev/null || true
    rm -f "/run/sandos-usb-docker-${uuid}.env"
    ;;
  *)
    echo "usage: sandos-usb-dockerd start <uuid> <mountpoint> | stop <uuid>" >&2
    exit 2
    ;;
esac
